c c d-DNNF compile: PROJECTED count over {1,2,3} (regression for nested ANDs).
c c Under the 1=true branch the residual formula splits into two
c c variable-disjoint components: {2,3} (the clause -2 v -3) and the projected-out
c c {4,5} (clause -4 v 5). The SAT oracle solves the {4,5} component and records a
c c witness, which the streaming compiler emits as a single-arc AND wrapper
c c (wrap_lits over TRUE). mk_and() then conjoins that wrapper with the {2,3}
c c sub-circuit, producing an AND-of-AND stack -- exactly the redundant
c c "AND -> AND -> literals" chain visible in ddnnf2dot before cleanup.
c c ddnnf-cleanup's flatten_ands pass must collapse it, and --strict verification
c c must then confirm no literal-free AND->AND arc survives. Projected count = 4.
c t pwmc
c p show 1 2 3 0
c c RUN: %solver --mode 1 --compile %t.nnf %s
c c RUN: %ddnnf_verify %t.nnf --expect-count 4 --no-strict
c c RUN: %ddnnf_cleanup %t.nnf %t.clean.nnf
c c RUN: %ddnnf_verify %t.clean.nnf --expect-count 4 --check-decomposable --strict
c c RUN: %ddnnf2dot %t.clean.nnf %t.dot
p cnf 6 2
1 2 0
-3 -1 -2 0
1 4 5 0
-4 5 0
1 3 0
