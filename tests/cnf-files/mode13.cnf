c c RUN: %solver --mode 13 --npolyvars 2 %s | %OutputCheck %s
p cnf 2 1
c t wmc
1 2 0
c p weight 1 z0+1 0
c p weight -1 z0^-1 0
c p weight 2 z1+1 0
c p weight -2 z1^-1 0
c c CHECK: ^s SATISFIABLE$
c c CHECK: ^c s exact laurent z0\*z1 \+ z0 \+ z1 \+ z0\*z1\^-1 \+ 1 \+ z0\^-1\*z1 \+ z1\^-1 \+ z0\^-1$
